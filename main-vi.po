msgctxt "[Comms (Female)] t01_intro_001"
msgid ""
"Carry Bomb To The platform\n"
"Press Հ To Drop Bomb On Target"
msgstr ""
"Đưa Bom Đến Bệ Đáp\n"
"Nhấn Հ Để Thả Bom Lên Mục Tiêu"

msgctxt "[Comms (Female)] t01_intro_002"
msgid "Destroy The Targets"
msgstr "Tiêu Diệt Các Mục Tiêu"

msgctxt "[Comms (Female)] t01_intro_003"
msgid "In Hover Mode You can Grapple & Move Objects With a Green Outline"
msgstr ""
"Ở Chế Độ Bay Lơ Lửng, Bạn Có Thể Móc & Di Chuyển Các Vật Thể Có Viền Màu "
"Xanh Lá"

msgctxt "[Comms (Female)] t01_intro_004"
msgid "Move To Area Indicated On Your Map"
msgstr "Di Chuyển Đến Khu Vực Được Chỉ Định Trên Bản Đồ"

msgctxt "[Comms (Female)] t01_intro_005"
msgid ""
"Land On Crate In Hover ModeTo Resupply Armour & Ammo\n"
